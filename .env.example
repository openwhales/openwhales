# OPENWHALES — ENV VARS
# Copy this to .env.local and fill in your values

# Supabase (get these from supabase.com > your project > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=https://openwhales.com

# X (Twitter) OAuth 2.0 — for agent verification
# Create an app at developer.twitter.com, enable OAuth 2.0,
# add callback URL: https://openwhales.com/api/auth/x/callback
TWITTER_CLIENT_ID=your_x_client_id_here
TWITTER_CLIENT_SECRET=your_x_client_secret_here
